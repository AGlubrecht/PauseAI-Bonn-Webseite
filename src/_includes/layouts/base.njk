<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="{{ '/assets/css/theme.css' | url }}">
  <link rel="stylesheet" href="{{ '/assets/css/layout.css' | url }}">
  <link rel="stylesheet" href="{{ '/assets/css/components.css' | url }}">

  <link rel="icon" href="{{ '/assets/images/favicon.ico' | url }}" sizes="48x48">
  <link rel="icon" href="{{ '/assets/images/bonn_logo.svg' | url }}" type="image/svg+xml">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ '/assets/images/favicon-32x32.png' | url }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ '/assets/images/favicon-16x16.png' | url }}">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/images/apple-touch-icon.png' | url }}">
</head>
<body>
  <div class="site">

    {# ===== HEADER / NAV ===== #}
    <header>
      <nav class="nav" role="navigation" aria-label="Hauptnavigation">
        <div class="nav__inner">
          <a href="{{ '/' | url }}" class="nav__brand">
            <div class="logo" role="img" aria-label="PauseAI Bonn Logo">
              <div class="logo__band"></div>
              <div class="logo__plaque"></div>
              <div class="logo__bar logo__bar--left"></div>
              <div class="logo__bar logo__bar--right"></div>
            </div>
            <span>{{ site.title }}</span>
          </a>

          <button class="nav__toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Navigation öffnen"><span class="nav__toggle-middle"></span></button>
        </div>

        <div class="nav__menu" id="main-nav">
          <ul class="nav__menu-internal">
            {% for item in site.nav %}
              <li><a href="{{ item.href }}" class="nav__link"{% if item.external %} target="_blank" rel="noopener"{% endif %}>{{ item.label }}</a></li>
            {% endfor %}
          </ul>
          <ul class="nav__menu-external">
            {% for org in site.parentOrgs %}
              <li><a href="{{ org.url }}" class="nav__link nav__link--external" target="_blank" rel="noopener">{{ org.label }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </nav>
    </header>

    {# ===== MAIN CONTENT ===== #}
    <main>
      {{ content | safe }}
    </main>

    {# ===== FOOTER ===== #}
    <footer class="footer">
      <div class="container footer__inner">
        <span>&copy; <script>document.write(new Date().getFullYear())</script> {{ site.title }}</span>
        <div class="footer__links">
          <a href="{{ '/impressum/' | url }}" class="footer__link">Impressum</a>
          <a href="{{ '/datenschutz/' | url }}" class="footer__link">Datenschutz</a>
        </div>
      </div>
    </footer>

  </div>

  <script src="{{ '/assets/js/nav.js' | url }}"></script>
  <script src="{{ '/assets/js/countdown.js' | url }}"></script>
</body>
</html>
