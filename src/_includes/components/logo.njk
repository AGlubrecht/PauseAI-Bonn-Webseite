{# CSS-only PauseAI Bonn logo — proportions from 800x800 SVG viewBox #}
{% macro logo(label="PauseAI Bonn Logo") %}
<div class="logo" role="img" aria-label="{{ label }}">
  <div class="logo__band"></div>
  <div class="logo__plaque"></div>
  <div class="logo__bar logo__bar--left"></div>
  <div class="logo__bar logo__bar--right"></div>
</div>
{% endmacro %}
