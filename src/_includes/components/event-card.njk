{#
  Event card component.
  Expects `event` with: date, title, subtitle  (status derived from date)
  Expects `time`, `location` from caller (events.time, events.location).
  Date format: "2026-03-18"
#}
{% macro eventCard(event, time, location) %}
  {% set months = ["Jan", "Feb", "Mär", "Apr", "Mai", "Jun", "Jul", "Aug", "Sep", "Okt", "Nov", "Dez"] %}
  {% set parts = event.date.split("-") %}
  {% set day = parts[2] | int %}
  {% set monthIdx = parts[1] | int - 1 %}
  {% set status = event.date | eventStatus %}

  <article class="event-card{% if status == 'past' %} event-card--past{% endif %}{% if status == 'tba' %} event-card--tba{% endif %}" data-event-date="{{ event.date }}" data-event-date-de="{{ event.date | deDate }}">
    <div class="event-card__date">
      <span class="event-card__date-day">{{ day }}</span>
      <span class="event-card__date-month">{{ months[monthIdx] }}</span>
    </div>
    <div class="event-card__body">
      <div class="event-card__title">{{ event.title }}</div>
      {% if event.subtitle %}
        <div class="event-card__subtitle">{{ event.subtitle }}</div>
      {% endif %}
      <div class="event-card__meta">{{ time }} · {{ location }}</div>
      {% if status == 'upcoming' %}
        <span class="event-card__badge event-card__badge--upcoming">Coming Up</span>
      {% endif %}
    </div>
  </article>
{% endmacro %}
