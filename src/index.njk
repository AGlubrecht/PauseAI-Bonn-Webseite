---
layout: layouts/base.njk
---

{% from "components/event-card.njk" import eventCard %}

{# ===== HERO ===== #}
{% set nextEvent = null %}
{% for event in events.events %}
  {% if not nextEvent and event.status == "upcoming" %}
    {% set nextEvent = event %}
  {% endif %}
{% endfor %}

<section class="hero" id="hero">
  <div class="container hero__inner">
    {% if nextEvent %}
    <div class="hero-event-wrapper">
      <span class="hero-event__label">
        <span class="hero-event__dot"></span>
        Nächstes Event
      </span>
      <div class="hero-event">
        <div class="hero-event__top">
          <span class="hero-event__countdown" data-event-date="{{ nextEvent.date }}" data-event-time="18:00">
            --:--:--:--
          </span>
        </div>
        <div class="hero-event__meta">
          {{ nextEvent.date | deDate }} · {{ events.time }}<br>
          {{ events.location }}
        </div>
        <div class="hero-event__title">{{ nextEvent.title }}</div>
        {% if nextEvent.subtitle %}
          <div class="hero-event__subtitle">{{ nextEvent.subtitle }}</div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    <div class="hero__bottom">
      <h1 class="hero__title">{{ sections.hero.title }}</h1>
      <div class="hero__links">
        {% for link in sections.hero.links %}
          <a href="{{ link.href }}" class="hero-link">
            <span>{{ link.label }}</span>
            <span class="hero-link__arrow">&darr;</span>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# ===== ABOUT ===== #}
<section class="section" id="about">
  <div class="container">
    <h2 class="section__title">{{ sections.about.title }}</h2>
    <div class="content-block">
      {{ sections.about.text | safe }}
    </div>
  </div>
</section>

{# ===== EVENTS ===== #}
<section class="section section--events" id="events">
  <div class="container">
    <h2 class="section__title">{{ events.seriesTitle }}</h2>
    <p class="section__subtitle">{{ events.seriesDescription }}</p>
    <div class="events-shadow-wrap">
      <div class="events-scroll">
        <div class="events-list">
          {% set foundNext = false %}
          {% for event in events.events %}
            {{ eventCard(event, events.time, events.location) }}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{# ===== MITMACHEN ===== #}
<section class="section" id="mitmachen">
  <div class="container">
    <h2 class="section__title">{{ sections.mitmachen.title }}</h2>
    {{ sections.mitmachen.text | safe }}
    <div class="events-list" style="margin-top: var(--spacing-md);">
      {% for action in sections.mitmachen.actions %}
        <article class="event-card">
          <div class="event-card__body">
            <div class="event-card__title">{{ action.title }}</div>
            <div class="event-card__subtitle">{{ action.description }}</div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{# ===== KONTAKT ===== #}
<section class="section" id="kontakt">
  <div class="container">
    <h2 class="section__title">{{ sections.kontakt.title }}</h2>
    <div class="contact-list">
      {% if site.contact.email %}
        <a href="mailto:{{ site.contact.email }}" class="contact-item">
          <span class="contact-item__icon"><svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="16" width="48" height="32"/><polyline points="8,16 32,36 56,16"/></svg></span>
          <div>
            <div class="contact-item__label">E-Mail</div>
            <div class="contact-item__value">{{ site.contact.email }}</div>
          </div>
        </a>
      {% endif %}
      {% if site.contact.discord %}
        <a href="{{ site.contact.discord }}" class="contact-item" target="_blank" rel="noopener">
          <span class="contact-item__icon"><svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23.3,5 L30.1,6.8 L29.6,9 L30.8,10.1 L35.2,9.5 L34.1,12.6 L36.6,12.9 L41.2,8.9 L48.6,12.7 L46.8,13.2 L48.9,14.1 L49.6,17.4 L48.2,20.3 L50.5,22.1 L51.7,33.1 L49,32.7 L39.3,38.3 L41.8,44 L47,48.5 L42.2,53.1 L43.4,57.6 L40.1,55.7 L35.8,58.2 L32.1,56.8 L31,59 L26.1,55.2 L26.9,56.2 L24,55.2 L24.1,56.7 L20.1,57.1 L19.7,53.1 L22.5,47.2 L14.4,43.8 L15.1,41.4 L13.3,39.6 L14.6,37.7 L12.3,32.8 L13.8,30.5 L12.7,27.4 L16.1,26.8 L17.5,24.5 L15.8,22.3 L18.3,19.2 L17.2,16.7 L17.9,14.8 L21.6,14.3 L22.6,16.4 L24.2,13.1 L26.3,13.2 L25.1,12.1 L25.7,10.1 L24.1,10.1 L25.8,8.6 L24.1,6.1 L22.8,7 L23.3,5 Z"/></svg></span>
          <div>
            <div class="contact-item__label">Discord</div>
            <div class="contact-item__value">PauseAI Deutschland Server</div>
          </div>
        </a>
      {% endif %}
      {% if site.contact.discordInternational %}
        <a href="{{ site.contact.discordInternational }}" class="contact-item" target="_blank" rel="noopener">
          <span class="contact-item__icon"><svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="32" cy="32" r="24"/><ellipse cx="32" cy="32" rx="10" ry="24"/><line x1="8" y1="32" x2="56" y2="32"/></svg></span>
          <div>
            <div class="contact-item__label">Discord (International)</div>
            <div class="contact-item__value">PauseAI Global Server</div>
          </div>
        </a>
      {% endif %}
      {% if site.contact.whatsapp %}
        <a href="{{ site.contact.whatsapp }}" class="contact-item" target="_blank" rel="noopener">
          <span class="contact-item__icon">&#128241;</span>
          <div>
            <div class="contact-item__label">WhatsApp</div>
            <div class="contact-item__value">WhatsApp-Gruppe beitreten</div>
          </div>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{# ===== LINKS ===== #}
<section class="section" id="links">
  <div class="container">
    <h2 class="section__title">{{ sections.links.title }}</h2>
    <div class="org-links">
      {% for link in sections.links.resources %}
        <a href="{{ link.url }}" class="org-link" target="_blank" rel="noopener">{{ link.label }}</a>
      {% endfor %}
    </div>
  </div>
</section>
